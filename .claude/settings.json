{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Bash(rm -rf *)",
      "Bash(curl *)"
    ],
    "defaultMode": "acceptEdits"
  }
}
